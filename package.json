{
  "name": "convex-voice-demo",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n convex,vite -c blue,green \"npm run dev:convex\" \"npm run dev:frontend\"",
    "dev:frontend": "vite",
    "dev:convex": "convex dev",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "ci": "npm run typecheck && npm run lint && npm run test:run && npm run build",
    "prepare": "husky"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.0",
    "@ai-sdk/openai-compatible": "1.0",
    "@cartesia/cartesia-js": "^3.0.0",
    "@convex-dev/agent": "^0.3.0",
    "ai": "^5.0.29",
    "convex": "^1.32.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "@eslint/js": "^9.39.0",
    "@playwright/test": "^1.58.0",
    "@testing-library/jest-dom": "^6.9.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.4.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.0",
    "convex-test": "^0.0.41",
    "eslint": "^9.39.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.0",
    "postcss": "^8.5.0",
    "prettier": "^3.8.0",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.4.0",
    "vitest": "^2.1.0"
  }
}
